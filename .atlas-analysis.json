  "keyFeatures": [
    "Embeddable odds widgets (Tile, Feed, Betslip, Odds Text, Promo Tiles, Bet Builder)",
    "JavaScript SDK with auto widget detection and lazy loading",
    "Multi-tenant workspace branding with light/dark theme support",
    "Sports analytics and pick tracking for analysts",
    "Community pick feeds with verified/all/community tabs",
    "Affiliate odds links with sportsbook integration",
    "WordPress shortcode and Web Component embed formats",
    "Real-time odds refresh and live game support"
  ],
  "publicApiSurface": [
    "Tallysight.scan([selector])",
    "Tallysight.loadWidget({ type?, element? })",
    "Tallysight.configure(options)",
    "Tallysight.enableAutoDetection() / disableAutoDetection()",
    "Tallysight.enableLazyLoading() / disableLazyLoading()",
    "Tallysight.enableBetBuilder() / disableBetBuilder()",
    "Tallysight.preloadWidget(type)",
    "Tallysight.trackCustomEvent(name, props?, domain?)",
    "Tallysight.isReady() / whenReady()",
    "Tallysight.getSdkState()",
    "data-tallysight-widget-type attribute",
    "data-tallysight-widget-id attribute",
    "data-tallysight-widget-config-* attributes",
    "data-tallysight-widget-loading (eager/lazy/auto)",
    "data-tallysight-defaults-widget-config-workspace",
    "data-tallysight-observer (MutationObserver toggle)",
    "data-tallysight-bet-builder-enabled",
    "data-tallysight-base-url (custom CDN)"
  ]
}
