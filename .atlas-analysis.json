  "projectDescription": "Tallysight is a sports betting analytics platform that lets analysts publish picks and insights, and lets publishers embed live odds widgets on their websites.",
  "theme": "luma",
  "primaryColor": "#008aff",
  "lightColor": "#e6f3ff",
